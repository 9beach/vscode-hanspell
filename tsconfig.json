{
  "compilerOptions": {
    "module": "commonjs",
    "moduleResolution": "node",
    "target": "es6",
    "outDir": "out",
    "lib": [
      "es6"
    ],
    "sourceMap": true,
    "rootDir": "src",
    "esModuleInterop": true,
    "strict": true,   /* enable all strict type-checking options */
    "useUnknownInCatchVariables": false
  },
  "exclude": [
    "node_modules",
    ".vscode-test"
  ]
}

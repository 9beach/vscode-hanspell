{
  "name": "vscode-hanspell",
  "displayName": "vscode-hanspell",
  "description": "(주)다음과 네이버(주)의 웹 서비스를 이용한 한글 맞춤법 검사기.",
  "version": "1.0.0",
  "icon": "images/hanspell.png",
  "publisher": "9beach",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Linters",
    "Other"
  ],
  "activationEvents": [
    "onCommand:vscode-hanspell.spellCheckByAll",
    "onCommand:vscode-hanspell.spellCheckByDAUM",
    "onCommand:vscode-hanspell.spellCheckByNAVER"
  ],
  "contributes": {
    "commands": [
      {
        "command": "vscode-hanspell.spellCheckByDAUM",
        "title": "맞춤법 검사 (다음)"
      },
      {
        "command": "vscode-hanspell.spellCheckByNAVER",
        "title": "맞춤법 검사 (네이버)"
      },
      {
        "command": "vscode-hanspell.spellCheckByAll",
        "title": "맞춤법 검사 (다음, 네이버)"
      }
    ]
  },
  "main": "./out/extension.js",
  "homepage": "https://github.com/9beach/vscode-hanspell",
  "author": {
    "name": "9beach",
    "email": "9beach@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/9beach/vscode-hanspell.git"
  },
  "bugs": {
    "url": "https://github.com/9beach/vscode-hanspell/issues"
  },
  "license": "MIT",
  "keywords": [
    "한스펠",
    "한글",
    "맞춤법",
    "한국어",
    "한국",
    "Hangul",
    "Spell Check",
    "SpellCheck",
    "Korean",
    "VS Code",
    "vscode",
    "spell",
    "Korea",
    "extension"
  ],
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.19.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "@typescript-eslint/parser": "^8.59.4",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^8.57.1",
    "glob": "^11.0.0",
    "mocha": "^11.7.6",
    "typescript": "^5.6.0"
  },
  "dependencies": {
    "hanspell": "^1.0.0"
  }
}
